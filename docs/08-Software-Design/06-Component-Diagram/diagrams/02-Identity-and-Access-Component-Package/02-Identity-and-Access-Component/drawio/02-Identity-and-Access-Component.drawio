;7. Record audit decision" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7B1FA2;strokeWidth=2;fontFamily=Arial;fontSize=12;fontStyle=1;fontStyle=0;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1"><mxGeometry x="1790" y="480" width="500" height="230" as="geometry"/></mxCell><mxCell id="legend" value="Legend&#xa;Blue = Presentation&#xa;Purple = Identity and access&#xa;Green = Related domain services&#xa;Orange = Repositories and adapters&#xa;Gray = Firebase and governance&#xa;Solid arrow = Required/provided interface&#xa;Deny-by-default authorization model" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#64748B;strokeWidth=2;fontFamily=Arial;fontSize=12;fontStyle=1;fontStyle=0;align=left;verticalAlign=top;spacing=10;" vertex="1" parent="1"><mxGeometry x="1790" y="850" width="500" height="210" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>