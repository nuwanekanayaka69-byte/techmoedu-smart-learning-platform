ExaminationManagement --> CourseManagement
MarksManagement --> ExaminationManagement
MarksManagement --> AttendanceManagement
ResourceManagement --> CourseManagement
ResourceManagement --> TeacherAssignment

PaymentManagement --> FeeManagement
PaymentManagement --> StudentManagement
AnnouncementManagement --> NotificationManagement
Reporting --> UserManagement
Reporting --> CourseManagement
Reporting --> EnrollmentManagement
Reporting --> AttendanceManagement
Reporting --> MarksManagement
Reporting --> PaymentManagement

UserManagement --> FirestoreRepository
InstituteManagement --> FirestoreRepository
TeacherManagement --> FirestoreRepository
StudentManagement --> FirestoreRepository
ParentManagement --> FirestoreRepository
RelationshipManagement --> FirestoreRepository
TeacherAssignment --> FirestoreRepository
CourseManagement --> FirestoreRepository
EnrollmentManagement --> FirestoreRepository
AttendanceManagement --> FirestoreRepository
ExaminationManagement --> FirestoreRepository
MarksManagement --> FirestoreRepository
FeeManagement --> FirestoreRepository
PaymentManagement --> FirestoreRepository
AnnouncementManagement --> FirestoreRepository
NotificationManagement --> FirestoreRepository
Reporting --> FirestoreRepository
Audit --> FirestoreRepository

ResourceManagement --> StorageAdapter
ResourceManagement --> FirestoreRepository
Authentication --> Audit
Authorization --> Audit
UserManagement --> Audit
InstituteManagement --> Audit
TeacherManagement --> Audit
StudentManagement --> Audit
ParentManagement --> Audit
RelationshipManagement --> Audit
