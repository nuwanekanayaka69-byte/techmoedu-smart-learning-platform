StorageAdapter --> FirebaseStorage
NotificationManagement --> FCM
NotificationManagement --> ExternalAdapter
PaymentManagement --> ExternalAdapter
ExternalAdapter --> PaymentGateway
ExternalAdapter --> EmailProvider
ExternalAdapter --> SMSProvider

Hosting --> PublicWebsite
Hosting --> AuthUI
Hosting --> SuperDashboard
Hosting --> InstituteDashboard
Hosting --> TeacherDashboard
Hosting --> StudentDashboard
Hosting --> ParentPortal

CloudFunctions --> Authentication
CloudFunctions --> Authorization
CloudFunctions --> UserManagement
CloudFunctions --> InstituteManagement
CloudFunctions --> TeacherManagement
CloudFunctions --> StudentManagement
CloudFunctions --> ParentManagement
CloudFunctions --> RelationshipManagement
CloudFunctions --> TeacherAssignment
CloudFunctions --> CourseManagement
CloudFunctions --> EnrollmentManagement
CloudFunctions --> AttendanceManagement
