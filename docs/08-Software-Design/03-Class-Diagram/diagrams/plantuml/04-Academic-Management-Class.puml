@startuml
title TechmoEDU Smart Learning Platform\n04 - Academic Management Class Diagram
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
hide empty members

package "Course Management" {
  class Course {
    - courseId: String
    - instituteId: String
    - courseCode: String
    - title: String
    - description: String
    - gradeLevel: String
    - subjectArea: String
    - status: CourseStatus
    - createdAt: Timestamp
    - updatedAt: Timestamp
    + create(): void
    + update(): void
    + publish(): void
    + archive(): void
  }

  class CourseCategory {
    - categoryId: String
    - name: String
    - description: String
    + create(): void
    + update(): void
  }

  class CoursePrerequisite {
    - prerequisiteId: String
    - courseId: String
    - requiredCourseId: String
    - mandatory: Boolean
    + validate(): Boolean
  }
}

package "Enrollment Management" {
  class Student {
    - studentId: String
    - studentNumber: String
    - gradeLevel: String
    - status: AccountStatus
    + viewAvailableCourses(): List<Course>
    + viewEnrollments(): List<Enrollment>
  }

  class Enrollment {
    - enrollmentId: String
    - studentId: String
    - courseId: String
    - enrolledAt: Timestamp
    - status: EnrollmentStatus
    - approvedBy: String
    + enroll(): void
    + approve(): void
    + suspend(): void
    + cancel(): void
  }

  class EnrollmentRequest {
    - requestId: String
    - studentId: String
    - courseId: String
    - requestedAt: Timestamp
    - status: RequestStatus
    + submit(): void
    + approve(): void
    + reject(): void
  }
}

package "Teaching & Scheduling" {
  class Teacher {
    - teacherId: String
    - employeeNumber: String
    - specialization: String
    + viewAssignedCourses(): List<Course>
    + scheduleSession(): ClassSession
  }

  class TeacherAssignment {
    - teacherAssignmentId: String
    - teacherId: String
    - courseId: String
    - instituteId: String
    - status: AssignmentStatus
    + assign(): void
    + deactivate(): void
  }

  class ClassSession {
    - classSessionId: String
    - courseId: String
    - teacherId: String
    - sessionDate: Date
    - startTime: Time
    - endTime: Time
    - deliveryMode: DeliveryMode
    - location: String
    - meetingUrl: String
    - status: SessionStatus
    + schedule(): void
    + reschedule(): void
    + cancel(): void
    + complete(): void
  }

  class Timetable {
    - timetableId: String
    - instituteId: String
    - academicYear: String
    - term: String
    + addSession(): void
    + removeSession(): void
    + detectConflict(): Boolean
  }
}

package "Learning Structure" {
  class Module {
    - moduleId: String
    - courseId: String
    - title: String
    - sequenceNumber: Integer
    - status: ModuleStatus
    + create(): void
    + reorder(): void
    + publish(): void
  }

  class Lesson {
    - lessonId: String
    - moduleId: String
    - title: String
    - sequenceNumber: Integer
    - durationMinutes: Integer
    - status: LessonStatus
    + create(): void
    + update(): void
    + publish(): void
  }

  class LearningOutcome {
    - outcomeId: String
    - lessonId: String
    - description: String
    - competencyLevel: String
    + define(): void
    + update(): void
  }
}

package "Academic Services & Audit" {
  class CourseService {
    + createCourse(data): Course
    + updateCourse(courseId, data): void
    + validatePrerequisites(studentId, courseId): Boolean
    + publishCourse(courseId): void
  }

  class EnrollmentService {
    + requestEnrollment(studentId, courseId): EnrollmentRequest
    + approveEnrollment(requestId): Enrollment
    + validateCourseLimit(studentId): Boolean
    + cancelEnrollment(enrollmentId): void
  }

  class SchedulingService {
    + scheduleSession(courseId, teacherId, time): ClassSession
    + detectTeacherConflict(teacherId, time): Boolean
    + detectCourseConflict(courseId, time): Boolean
  }

  class AcademicAuditLog {
    - auditLogId: String
    - actorId: String
    - courseId: String
    - action: String
    - entityType: String
    - entityId: String
    - createdAt: Timestamp
    + write(): void
  }
}

CourseCategory "1" -- "0..*" Course
Course "1" -- "0..*" CoursePrerequisite
Course "1" -- "0..*" Enrollment
Student "1" -- "0..5" Enrollment
Student "1" -- "0..*" EnrollmentRequest
Course "1" -- "0..*" EnrollmentRequest

Teacher "1" -- "0..*" TeacherAssignment
Course "1" -- "0..*" TeacherAssignment
Course "1" *-- "0..*" ClassSession
Teacher "1" -- "0..*" ClassSession
Timetable "1" o-- "0..*" ClassSession

Course "1" *-- "1..*" Module
Module "1" *-- "1..*" Lesson
Lesson "1" *-- "1..*" LearningOutcome

CourseService ..> Course
CourseService ..> CoursePrerequisite
EnrollmentService ..> EnrollmentRequest
EnrollmentService ..> Enrollment
EnrollmentService ..> Student
SchedulingService ..> ClassSession
SchedulingService ..> Teacher
SchedulingService ..> Course

Course "1" -- "0..*" AcademicAuditLog
Student "0..1" -- "0..*" AcademicAuditLog
Teacher "0..1" -- "0..*" AcademicAuditLog

note right of Enrollment
Business rule:
A student may have a maximum
of 5 active course enrollments.
end note

note right of ClassSession
Business rule:
Teacher and course schedule
conflicts must be prevented.
end note

note bottom of Course
Every course belongs to one institute.
end note
@enduml
