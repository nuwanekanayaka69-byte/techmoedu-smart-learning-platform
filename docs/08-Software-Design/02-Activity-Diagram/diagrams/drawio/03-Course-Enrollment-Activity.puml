@startuml
title TechmoEDU Smart Learning Platform - Course Enrollment Activity

|Institute Administrator|
start
:Search Student;
:Select Student;
:View Available Courses;
:Select Course(s);
:Confirm Enrollment;

|TechmoEDU System|
:Find Student Record;

if (Student Found?) then (Yes)
  :Load Active Courses;
  if (Course Available?) then (Yes)
    if (Course Limit Reached? (5)) then (Yes)
      :Show Maximum Course Limit Error;
      |Institute Administrator|
      :Reduce Course Count;
      stop
    else (No)
      if (Already Enrolled?) then (Yes)
        :Show Already Enrolled Error;
        |Institute Administrator|
        :Choose Another Course;
        stop
      else (No)
        :Create Enrollment Record;
        :Update Firestore Enrollments;
        :Notify Student;
        :Display Success Message;
        stop
      endif
    endif
  else (No)
    :Show Course Unavailable Error;
    |Institute Administrator|
    :Choose Another Course;
    stop
  endif
else (No)
  :Show Student Not Found Error;
  |Institute Administrator|
  :Retry Student Search;
  stop
endif

@enduml
