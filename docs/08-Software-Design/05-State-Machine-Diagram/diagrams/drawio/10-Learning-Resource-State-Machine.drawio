ule:&#xa;Files remain quarantined until scanning passes.&#xa;Unsafe resources are blocked or deleted." style="shape=note;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#757575;fontFamily=Arial;fontSize=12;" vertex="1" parent="1"><mxGeometry x="40" y="510" width="360" height="120" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>