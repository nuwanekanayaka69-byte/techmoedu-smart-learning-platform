@startuml
left to right direction
title Student & Parent Use Case Diagram
actor Student as S
actor Parent as P
rectangle "TechmoEDU Smart Learning Platform" {
 usecase "Login" as U1
 usecase "Update Profile" as U2
 usecase "View Enrolled Courses" as U3
 usecase "Access Learning Resources" as U4
 usecase "View Attendance" as U5
 usecase "View Results" as U6
 usecase "View Fee Status" as U7
 usecase "View Announcements" as U8
 usecase "View Linked Children" as U9
 usecase "View Child Progress" as U10
 usecase "Verify Credentials" as U11
 usecase "Check Ownership Permission" as U12
}
S --> U1
S --> U2
S --> U3
S --> U4
S --> U5
S --> U6
S --> U7
S --> U8
P --> U1
P --> U2
P --> U9
P --> U10
P --> U8
P --> U7
P --> U6
P --> U5
U1 ..> U11 : <<include>>
U11 ..> U12 : <<include>>
U5 ..> U12 : <<include>>
U6 ..> U12 : <<include>>
U7 ..> U12 : <<include>>
U10 ..> U9 : <<include>>
U4 ..> U3 : <<extend>>
U10 ..> U6 : <<extend>>
U10 ..> U5 : <<extend>>
@enduml
